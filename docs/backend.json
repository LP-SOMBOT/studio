
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information stored in Firestore.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "phoneNumber": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "A game package purchase order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "successful", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "paymentMethod": { "type": "string" },
        "gameDetails": { "type": "object" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles for both admins and customers."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of all game top-up and account orders."
    }
  }
}
