
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information stored in Realtime Database.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "number" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a conversation.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "senderId": { "type": "string" },
        "timestamp": { "type": "number" },
        "isRead": { "type": "boolean" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A game package purchase order stored in Realtime Database.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "successful", "cancelled"] },
        "createdAt": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "gameDetails": { "type": "object" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "StoreSettings": {
      "title": "Store Settings",
      "description": "Global configuration for the application.",
      "type": "object",
      "properties": {
        "isLive": { "type": "boolean" },
        "announcementTicker": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "database": {
    "users": {
      "description": "User profiles managed via uid keys."
    },
    "orders": {
      "description": "All orders created by users."
    },
    "settings": {
      "description": "Global application settings like live status."
    },
    "chats": {
      "description": "Message history keyed by userId."
    },
    "chatIndex": {
      "description": "Metadata about conversations for admin view."
    }
  }
}
