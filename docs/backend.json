
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information stored in Realtime Database.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "staff", "admin", "super_admin"] },
        "phoneNumber": { "type": "string" },
        "points": { "type": "number" },
        "createdAt": { "type": "number" },
        "photoURL": { "type": "string" },
        "gameName": { "type": "string" },
        "gameUid": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Game": {
      "title": "Game",
      "description": "A game collection containing multiple top-up packages.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "icon": { "type": "string" },
        "category": { "type": "string", "enum": ["top-up", "accounts"] },
        "createdAt": { "type": "number" }
      }
    },
    "AccountPost": {
      "title": "Account Post",
      "description": "A user-submitted game account for sale.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "platform": { "type": "string", "enum": ["Google", "Facebook"] },
        "level": { "type": "number" },
        "age": { "type": "string" },
        "primeLevel": { "type": "number" },
        "items": { "type": "array" },
        "price": { "type": "number" },
        "fee": { "type": "number" },
        "totalCharge": { "type": "number" },
        "thumbnailUrl": { "type": "string" },
        "imageUrls": { "type": "array" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "approved", "rejected"] },
        "createdAt": { "type": "number" },
        "views": { "type": "number" },
        "sold": { "type": "boolean" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification document.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "linkTo": { "type": "string" },
        "icon": { "type": "string" }
      }
    },
    "Event": {
      "title": "Event",
      "description": "Active game events.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "shortDescription": { "type": "string" },
        "content": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["freefire_event", "general"] },
        "active": { "type": "boolean" },
        "expiresAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "database": {
    "users": { "description": "User profiles" },
    "games": { "description": "Game collections (Free Fire, PUBG, etc.)" },
    "accountPosts": { "description": "Marketplace account listings" },
    "orders": { "description": "Unified orders node for top-ups and accounts" },
    "notifications": { "description": "User-specific notifications" },
    "settings": { "description": "Global shop configuration and fees" },
    "events": { "description": "Active game events" },
    "products": { "description": "Inventory items belonging to specific games" },
    "chats": { "description": "Real-time support chat messages" },
    "chatIndex": { "description": "Admin dashboard for active chat sessions" }
  }
}
